<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    FiltersView.fxml — Filter panel embedded in the main content area
    Controller: bm.gui.FiltersView
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="bm.gui.FiltersView"
      stylesheets="@../css/styles.css"
      style="-fx-background-color:#0D0F14;"
      spacing="0">

    <!-- Top bar -->
    <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
        <Label text="Filter Books" styleClass="label-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Clear All" styleClass="button" onAction="#clearFilters"/>
        <Button text="Apply Filters" styleClass="btn-primary" onAction="#applyFilters"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="20" style="-fx-padding:24;">

            <!-- Genre & Status row -->
            <HBox spacing="20">
                <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="GENRE" styleClass="label-section"/>
                    <ComboBox fx:id="genreCombo" promptText="All genres" maxWidth="Infinity"/>
                </VBox>
                <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
                    <Label text="READING STATUS" styleClass="label-section"/>
                    <ComboBox fx:id="statusCombo" promptText="All statuses" maxWidth="Infinity"/>
                </VBox>
            </HBox>

            <!-- Year range card -->
            <VBox styleClass="card" spacing="14">
                <Label text="PUBLICATION YEAR RANGE" styleClass="label-section"/>
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="From" styleClass="detail-label"/>
                        <Spinner fx:id="yearMinSpinner" min="1000" max="2100"
                                 initialValue="1900" editable="true" maxWidth="Infinity"/>
                    </VBox>
                    <Label text="→" styleClass="label-secondary"
                           style="-fx-font-size:18px; -fx-padding:16 0 0 0;"/>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="To" styleClass="detail-label"/>
                        <Spinner fx:id="yearMaxSpinner" min="1000" max="2100"
                                 initialValue="2025" editable="true" maxWidth="Infinity"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Pages range card -->
            <VBox styleClass="card" spacing="14">
                <Label text="MAX PAGE COUNT" styleClass="label-section"/>
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <Slider fx:id="pagesSlider" min="0" max="2000" value="2000"
                            showTickLabels="true" showTickMarks="true"
                            majorTickUnit="500" blockIncrement="50"
                            HBox.hgrow="ALWAYS"/>
                    <Label fx:id="pagesSliderLabel" text="2000 pages"
                           styleClass="label-secondary" style="-fx-min-width:90;"/>
                </HBox>
            </VBox>

            <!-- Minimum rating card -->
            <VBox styleClass="card" spacing="14">
                <Label text="MINIMUM RATING" styleClass="label-section"/>
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <Slider fx:id="minRatingSlider" min="0" max="5" value="0"
                            showTickLabels="true" showTickMarks="true"
                            majorTickUnit="1" blockIncrement="0.5"
                            HBox.hgrow="ALWAYS"/>
                    <Label fx:id="ratingSliderLabel" text="0.0 ★"
                           styleClass="label-secondary" style="-fx-min-width:50;"/>
                </HBox>
            </VBox>

            <!-- Results count -->
            <HBox>
                <Label fx:id="filterResultCount" text="" styleClass="label-secondary"/>
            </HBox>

        </VBox>
    </ScrollPane>
</VBox>
